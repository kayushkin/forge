# Forge Environment {{.Env}}
# Ports: {{.BasePort}}-{{.MaxPort}}
# Generated by forge — do not edit manually

name: forge-env-{{.Env}}

services:
  bus:
    build:
      context: ${REPOS_DIR}/bus
      dockerfile: ${FORGE_DIR}/deploy/dockerfiles/Dockerfile.go-service
      args:
        SERVICE_DIR: ./cmd/bus
    restart: unless-stopped
    ports:
      - "{{.BusPort}}:8100"
    volumes:
      - bus-data:/data
    command: ["--addr", "0.0.0.0:8100", "--db", "/data/bus.db", "--token", "${BUS_TOKEN:-forge-env-{{.Env}}}"]
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8100/stats?token=${BUS_TOKEN:-forge-env-{{.Env}}}"]
      interval: 30s
      timeout: 5s
      retries: 3

  si:
    build:
      context: ${REPOS_DIR}/si
      dockerfile: ${FORGE_DIR}/deploy/dockerfiles/Dockerfile.go-service
      args:
        SERVICE_DIR: ./cmd/si
    restart: unless-stopped
    ports:
      - "{{.SiPort}}:8120"
    environment:
      - SI_WS_ADDR=0.0.0.0:8120
      - SI_BUS_URL=http://bus:8100
      - SI_BUS_TOKEN=${BUS_TOKEN:-forge-env-{{.Env}}}
    depends_on:
      bus:
        condition: service_healthy

  logstack:
    build:
      context: ${REPOS_DIR}/logstack
      dockerfile: ${FORGE_DIR}/deploy/dockerfiles/Dockerfile.logstack
    restart: unless-stopped
    ports:
      - "{{.LogstackPort}}:8088"
    volumes:
      - logstack-data:/data
    environment:
      - LOGSTACK_PORT=8088
    depends_on:
      bus:
        condition: service_healthy

  inber:
    build:
      context: ${REPOS_DIR}
      dockerfile: ${FORGE_DIR}/deploy/dockerfiles/Dockerfile.inber
    restart: unless-stopped
    volumes:
      - inber-data:/data
    environment:
      - BUS_URL=http://bus:8100
      - BUS_TOKEN=${BUS_TOKEN:-forge-env-{{.Env}}}
      - BUS_CONSUMER=bus-agent-env-{{.Env}}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
    command: ["-bus", "http://bus:8100", "-token", "${BUS_TOKEN:-forge-env-{{.Env}}}", "-consumer", "bus-agent-env-{{.Env}}", "-db", "/data/agents.db"]
    depends_on:
      bus:
        condition: service_healthy

  kayushkin:
    build:
      context: ${REPOS_DIR}/kayushkin.com
      dockerfile: ${FORGE_DIR}/deploy/dockerfiles/Dockerfile.kayushkin
    restart: unless-stopped
    ports:
      - "{{.WebPort}}:8080"
    volumes:
      - kayushkin-data:/data
    environment:
      - PORT=8080
      - HOST=0.0.0.0
      - BUILD_PATH=/srv/build
      - BUS_URL=http://bus:8100
      - BUS_TOKEN=${BUS_TOKEN:-forge-env-{{.Env}}}
      - KAYUSHKIN_PASSPHRASE=${KAYUSHKIN_PASSPHRASE:-forge-dev-{{.Env}}}
      - SI_WS_URL=ws://si:8120/ws
      - LOGSTACK_URL=http://logstack:8088
      - FORGE_API_URL=http://host.docker.internal:8150
      - BUS_AGENT_API_URL=http://host.docker.internal:8101
    extra_hosts:
      - "host.docker.internal:host-gateway"
    depends_on:
      bus:
        condition: service_healthy

volumes:
  bus-data:
  kayushkin-data:
  logstack-data:
  inber-data:
