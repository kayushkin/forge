# Forge Environment {{.Env}}
# Ports: {{.BasePort}}-{{.MaxPort}}
# Generated by forge — do not edit manually

name: forge-env-{{.Env}}

services:
  bus:
    build:
      context: ${REPOS_DIR}/bus
      dockerfile: ${FORGE_DIR}/deploy/dockerfiles/Dockerfile.go-service
      args:
        SERVICE_DIR: ./cmd/bus
    restart: unless-stopped
    ports:
      - "{{.BusPort}}:8100"
    volumes:
      - bus-data:/data
    command: ["--addr", "0.0.0.0:8100", "--db", "/data/bus.db", "--token", "${BUS_TOKEN:-forge-env-{{.Env}}}"]
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8100/stats?token=${BUS_TOKEN:-forge-env-{{.Env}}}"]
      interval: 30s
      timeout: 5s
      retries: 3

  si:
    build:
      context: ${REPOS_DIR}/si
      dockerfile: ${FORGE_DIR}/deploy/dockerfiles/Dockerfile.go-service
      args:
        SERVICE_DIR: ./cmd/si
    restart: unless-stopped
    ports:
      - "{{.SiPort}}:8120"
    environment:
      - SI_WS_ADDR=0.0.0.0:8120
      - SI_BUS_URL=http://bus:8100
      - SI_BUS_TOKEN=${BUS_TOKEN:-forge-env-{{.Env}}}
    depends_on:
      bus:
        condition: service_healthy

  kayushkin:
    build:
      context: ${REPOS_DIR}/kayushkin.com
      dockerfile: ${FORGE_DIR}/deploy/dockerfiles/Dockerfile.kayushkin
    restart: unless-stopped
    ports:
      - "{{.WebPort}}:8080"
    volumes:
      - kayushkin-data:/data
    environment:
      - PORT=8080
      - BUS_URL=http://bus:8100
      - BUS_TOKEN=${BUS_TOKEN:-forge-env-{{.Env}}}
    depends_on:
      bus:
        condition: service_healthy

volumes:
  bus-data:
  kayushkin-data:
