FROM golang:1.24-bookworm AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN cd cmd/logstack && CGO_ENABLED=0 go build -buildvcs=false -o /logstack .

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /logstack /usr/local/bin/logstack
ENTRYPOINT ["logstack"]
